# Copy this file to .env and fill in the values

# --- Database ---
DATABASE__POSTGRES_USER=your_user
DATABASE__POSTGRES_PASSWORD=your_password

# Used by docker-compose to create the PostgreSQL container
POSTGRES_USER=your_user
POSTGRES_PASSWORD=your_password
POSTGRES_DB=remonline

# --- Keycloak ---
KEYCLOAK__KEYCLOAK_USERNAME=your_keycloak_admin
KEYCLOAK__KEYCLOAK_PASSWORD=your_keycloak_password
KEYCLOAK_ADMIN_PASSWORD=your_keycloak_admin_password
